{% extends 'base.html.twig' %}
{% block title %}Gestion des livreurs{% endblock %}
{% block body %}
<div style="max-width:700px;margin:2rem auto;font-family:sans-serif">
    <h1>Livreurs</h1>
    {% for msg in app.flashes('success') %}
        <div style="background:#d4edda;padding:.75rem;border-radius:4px;margin-bottom:1rem">{{ msg }}</div>
    {% endfor %}
    <a href="{{ path('admin_livreur_new') }}" style="background:#6a5acd;color:#fff;padding:8px 16px;text-decoration:none;border-radius:4px">+ Nouveau livreur</a>
    <a href="{{ path('admin_products') }}" style="margin-left:1rem;color:#6a5acd">Gérer les produits</a>
    <table style="width:100%;border-collapse:collapse;margin-top:1.5rem">
        <thead>
            <tr style="background:#6a5acd;color:#fff">
                <th style="padding:8px;text-align:left">Email</th>
                <th style="padding:8px">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for livreur in livreurs %}
            <tr style="border-bottom:1px solid #ddd">
                <td style="padding:8px">{{ livreur.email }}</td>
                <td style="padding:8px;text-align:center">
                    <form method="post" action="{{ path('admin_livreur_delete', {id: livreur.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce livreur ?')">
                        <button type="submit" style="background:none;border:none;color:red;cursor:pointer">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="2" style="padding:8px;text-align:center">Aucun livreur.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
